\usepackage{hyperref}
\usepackage{xcolor}
\definecolor{accent}{rgb}{0.0, 0.72, 0.67}
\definecolor{mygray}{gray}{0.6}
\definecolor{titlegray}{gray}{0}
\hypersetup{colorlinks,linkcolor={accent},citecolor={accent},urlcolor={accent}}

\usepackage{fontawesome5}
\usepackage{amsmath}
\usepackage{lmodern}
\usepackage[T1]{fontenc}

% palatino-style serif, with old-style figures (osf) so digits in dates
% have ascenders/descenders instead of sitting uniformly on the baseline
\usepackage[osf]{newpxtext}

% Experimental:
%   \usepackage{tgpagella}                 % TeX Gyre Pagella (lining figures)
%   \usepackage[ScaleRM=1.08]{libertinus}  % Libertinus Serif at 1.08 scale

% typographic refinements (font expansion + character protrusion).
\usepackage[expansion,protrusion]{microtype}

%%% DOCUMENT WIDE

\pagestyle{empty}
\setlength{\tabcolsep}{0em}
\xspaceskip7pt  % more spacing between sentences
\sloppy  % prefer wider word spacing over text poking past the right margin

%%% COMMANDS

% main title: name + date in the top-right corner
% The date is set in a deliberately zero-height \vbox so it floats in the
% top-right corner without taking vertical space; the local \vfuzz silences
% the (harmless, expected) "overfull \vbox" report this trick provokes.
\newcommand\maintitle[2]{%
  \begingroup\vfuzz\maxdimen
  \vbox to 0pt{\hfill\emph{\textcolor{mygray}{#2}}}%
  \endgroup
  \vspace{-0.4em}\noindent{\huge \textbf{\textsc{#1}}}}

% titles for root sections
\newcommand*\roottitle[1]{
\subsection*{\textsc{\textcolor{titlegray}{#1}}}\vspace{-0.4em}\nopagebreak[4]}

% toggle fontawesome icons in section titles on/off
\newif\ifshowicons
\showiconsfalse  % \showiconstrue to show icons, \showiconsfalse to hide
\newcommand{\icon}[1]{\ifshowicons #1\fi}

% section title: title + optional (toggleable) icon
\newcommand{\sectiontitle}[2]{\roottitle{#1\hspace{0.1cm}\icon{#2}}}

% pretty bullet. includes surrounding spacing
\newcommand*\sbull{\ \ $\boldsymbol{\cdot}$ \ \ }

% fontawesome icon nudged down so it sits centered on the text baseline
\newcommand{\contacticon}[1]{\raisebox{-0.35ex}{#1}}
% contact item set off by a gap: icon followed by a label link
\newcommand{\contact}[3]{\hspace{0.5cm}\contacticon{#1}~\href{#2}{#3}}

% it seems not to work when simply using \parindent...
\newlength{\newparindent}
\addtolength{\newparindent}{\parindent}

% indentsection style, used for sections that aren't already in lists
% that need indentation to the level of all text in the document
\newenvironment{indentsection}%
{
  \begin{list}{}%
    {\setlength{\leftmargin}{\newparindent}\setlength{\parsep}{0pt}\setlength{\parskip}{0pt}\setlength{\itemsep}{0pt}\setlength{\topsep}{0pt}}%
  }
  {
\end{list}}

\newcommand{\bodytext}[1]{\nopagebreak[4]
  \begin{indentsection}
  \item[]#1
\end{indentsection}\pagebreak[2]}

% cv entry: bold title, meta line, optional indented body
\NewDocumentCommand{\headedsubsection}{s m m +g}{%
  \nopagebreak[4]
  \begin{indentsection}
  \item[]%
    \textbf{#2}%
    \IfBooleanTF{#1}{{\sbull #3}}{\emph{\textcolor{mygray}{\sbull #3}}}%
    \IfValueT{#4}{\bodytext{#4}}%
\end{indentsection}\nopagebreak[4]}

\newcommand{\nobreakvspace}[1]{\nopagebreak[4]\vspace{#1}\nopagebreak[4]}
